<?xml version="1.0"?>
<!--
  Переопределяем пароль пользователя default через SHA-256 хэш.
  Значение берётся из Vault — на диск ноды попадает только хэш, не открытый текст.
  Атрибут remove="1" сначала убирает дефолтный пустой пароль из users.xml,
  затем выставляем sha256 из нашего Vault.
-->
<clickhouse>
    <users>
        <default>
            <password remove="1"/>
            <password_sha256_hex>{{ clickhouse_default_password | hash('sha256') }}</password_sha256_hex>
        </default>
    </users>
</clickhouse>
